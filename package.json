      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/google-apps-script": "^1.0.14",
    "@types/jest": "^29.5.12",
    "codelyzer": "^6.0.0",
    "jest": "^29.7.0",
    "prettier": "^2.0.5",
    "pretty-quick": "^2.0.1",
    "ts-jest": "^29.1.4",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^5.4.5"
  },
  "author": "",
  "license": "ISC",
  "prettier": {
    "printWidth": 140,
    "singleQuote": true,
